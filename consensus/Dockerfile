FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY consensus /app/consensus

RUN python -m pip install --upgrade pip setuptools wheel && \
    python -m pip install /app/consensus

WORKDIR /app/consensus

CMD ["sh", "-c", "python -m consensus --validators \"${CONSENSUS_VALIDATORS:-24}\" --epochs \"${CONSENSUS_EPOCHS:-6}\""]

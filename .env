COMPOSE_PROJECT_NAME=python-ethereum-client

# This is this repository's own chain, not Ethereum mainnet/testnet.
EXECUTION_RPC_HOST=0.0.0.0
EXECUTION_RPC_PORT=8545
EXECUTION_CHAIN_ID=1337
EXECUTION_MINING_MODE=instant
EXECUTION_PRIVACY_NETWORK=i2p
EXECUTION_DATA_DIR=./data/execution
EXECUTION_STATE_ROOT=/var/lib/crypto/execution
EXECUTION_NODE_STATUS_INTERVAL=300
# Comma-separated bootstrap and static peer references for the long-running
# execution demo roles. Use the Compose service name for a single-host stack
# or replace with external host:port values for remote deployments.
EXECUTION_BOOTNODES=execution-bootnode
EXECUTION_STATIC_PEERS=
EXECUTION_I2P_SAM_HOST=i2p-router
EXECUTION_I2P_SAM_PORT=7656
EXECUTION_I2P_SIGNATURE_TYPE=7
EXECUTION_I2P_INBOUND_QUANTITY=2
EXECUTION_I2P_OUTBOUND_QUANTITY=2
EXECUTION_I2P_TIMEOUT_SECONDS=15
EXECUTION_I2P_BOOTSTRAP_FILE=/var/lib/crypto/execution/i2p/bootstrap-peers.txt
EXECUTION_I2P_BOOTSTRAP_WAIT_SECONDS=20
EXECUTION_I2P_PUBLISH_DESTINATION=false

I2P_DATA_DIR=./data/i2p
I2P_CONSOLE_PORT=7657

CONSENSUS_VALIDATORS=24
CONSENSUS_EPOCHS=6
